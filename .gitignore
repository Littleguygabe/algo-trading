# --- Python Internals ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# --- Virtual Environments ---
# Your specific venv folder
venv/
# Common aliases for venvs (just in case)
env/
.env/
.venv/

# --- Distribution / Build ---
build/
dist/
wheels/
*.egg-info/
.eggs/

# --- Testing & Code Quality ---
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# --- Environment Variables (Security) ---
# NEVER commit secrets or API keys
.env

# --- IDEs & Editors (Optional but recommended) ---
# VS Code
.vscode/
# PyCharm / IntelliJ
.idea/
# Mac OS
.DS_Store

# --- Jupyter Notebooks ---
.ipynb_checkpoints